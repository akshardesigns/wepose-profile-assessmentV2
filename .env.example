# Port untuk server Express
PORT=3000

# ID Google Sheet (ambil dari URL sheet-nya)
# https://docs.google.com/spreadsheets/d/<INI_SHEET_ID_NYA>/edit
SHEET_ID=

# Nama tab/sheet tempat data assessment disimpan
SHEET_NAME=AssessmentsII

# --- Untuk development lokal (pilih salah satu) ---
# Path ke file service account JSON (lihat README bagian setup Google Sheets)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# --- Untuk deploy di Vercel (wajib pakai ini, bukan yang di atas) ---
# Isi seluruh file service-account.json sebagai satu baris JSON.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=

# Base URL server (dipakai Puppeteer untuk buka halaman print.html secara internal)
# Di Vercel biasanya tidak perlu diisi manual (otomatis pakai VERCEL_URL),
# tapi kalau pakai custom domain sebaiknya diisi eksplisit, mis:
# BASE_URL=https://nama-app-kamu.vercel.app
BASE_URL=http://localhost:3000
